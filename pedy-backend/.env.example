# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Firebase Admin SDK ───────────────────────────────
# Path to the service account JSON key downloaded from Firebase Console
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# ─── M-Pesa Daraja API ────────────────────────────────
# From https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=YOUR_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_CONSUMER_SECRET
MPESA_SHORTCODE=YOUR_SHORTCODE
MPESA_PASSKEY=YOUR_LIPA_NA_MPESA_PASSKEY
# sandbox | production
MPESA_ENVIRONMENT=sandbox
# Publicly accessible URL for M-Pesa to POST results to
MPESA_CALLBACK_BASE_URL=https://your-backend-url.com

# ─── CORS ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
