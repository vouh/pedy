# ─── Server ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Firebase Admin SDK ─────────────────────────────────────────────────────
# Path to the Firebase service account JSON key.
# This is the SAME service-account.json used by pedy-backend.
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=../../pedy-backend/service-account.json

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (where your admin HTML lives).
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://127.0.0.1:5501,http://localhost:3000
